<?xml version="1.0"?>
<log4net>

	<!-- ExceptionAppender knows how to insert records into the ErrorLog table in the CentralServcies database -->
	<appender name="ExceptionAppender" type="Hunt.EPIC.Logging.ExceptionAppender" />
	
	<appender name="RollingLogFileAppender" type="log4net.Appender.RollingFileAppender">
		<file value="..\Logs\GPRSComService\GPRSScheduler.log" />
		<appendToFile value="true" />
		<rollingStyle value="Composite" />
		<datePattern value="yyyyMMdd" />
		<maxSizeRollBackups value="10" />
		<maximumFileSize value="50MB" />
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" />
		</layout>
	</appender>

  <appender name="DALAppender" type="log4net.Appender.RollingFileAppender">
    <file value="..\Logs\GPRSComService\GPRSScheduler.log" />
    <appendToFile value="true" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyyMMdd" />
    <maxSizeRollBackups value="10" />
    <maximumFileSize value="50MB" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" />
    </layout>
  </appender>
  <!-- Configure a default exception logger that uses ExceptionAppender. 
	     Without this the delegate that is passed to the logging component will not be called -->
  <logger name="ExceptionLogger">
    <level value="ERROR" />
    <appender-ref ref="ExceptionAppender" />
    <!-- let us see the exceptions in log file too -->
    <appender-ref ref="RollingLogFileAppender" />
  </logger>
  
  <logger name="cabcon.Data" additivity="false">
    <level value="DEBUG" />
    <appender-ref ref="DALAppender" />
  </logger>
	<!--<appender name="TraceAppender" type="log4net.Appender.TraceAppender">
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" />
		</layout>
	</appender -->

	<root>
		<level value="DEBUG" />
		<appender-ref ref="RollingLogFileAppender" />
		<!-- appender-ref ref="TraceAppender" / -->
	</root>
	
</log4net>
