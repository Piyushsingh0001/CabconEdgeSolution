<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler,log4net, Version=1.2.10.0, Culture=neutral, PublicKeyToken=1b44e1d426115821"/>
  </configSections>
  
  <appSettings>
     <add key="GPRSAdapterConnectionKey" value="Data Source=182.71.32.185;Initial Catalog=GprsAdapter_CommManager;Persist Security Info=True;User ID=sa;Password=Landis@123"/>
     <add key="GPRSRoutingServiceConnectionKey" value="Data Source=182.71.32.185;Initial Catalog=GprsAdapter_RoutingService;Persist Security Info=True;User ID=sa;Password=Landis@123"/>
     <add key="GPRSInteractionIsService" value="true"/>
     <add key="ConnectionString" value="server=127.0.0.1;database=DND;user=root;port=3308;password=Password12;"/>
     <add key="DBTYPE" value="My_SQL"/>
    <add key="ApplicationType" value="DLMS_LTCT_650"/>
    <add key="DataBaseName" value="dlms_ltct_650"/>
    <add key="TaskExpiryTimeOutMinutes" value="3"/>
    <add key="CommandProcessorIdleTimeout" value="10"/>
    <add key="FileUploaderIdleTimeout" value="10"/>
    <add key="NewTaskWorkerIdleTimeout" value="4000"/>
    <add key="ProcessTaskWorkerIdleTimeout" value="10000"/>
    <add key="ResponseProcessorIdleTimeout" value="10"/>
    <add key="maxProcessTaskWorkerThread" value="1"/>
    <add key="maxResponseProcessorThread" value="1"/>
    <add key="maxCommandProcessorThread" value="1"/>
    <add key="maxFileUploadProcessorThread" value="1"/>
    <add key="EndPointSyncSleepDuration" value="600"/>
    <add key="CommandExpiryTimeOut" value="90"/>
    <add key="WaitIntervalBeforeAbort" value="60"/>
    <add key="MaxLoadSurveyDays" value="30"/>
  </appSettings>
  
  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="AdapterTCPBinding" openTimeout="00:02:00" closeTimeout="00:02:00" receiveTimeout="00:02:00" sendTimeout="00:02:00">
          <security mode="None"></security>
          </binding>
      </netTcpBinding>
    </bindings>
    <client>
   
      <endpoint address="net.tcp://182.71.32.185:9011/GPRSAdapter/NetworkProtocolMessageReceiver.svc" binding="netTcpBinding" name="tcpEndPoint" contract="INetworkProtocol" bindingConfiguration="AdapterTCPBinding"/>

      <endpoint address="net.tcp://182.71.32.185:9011/GPRSAdapter/EndpointOperations.svc" binding="netTcpBinding" name="GPRSAdapterEndPointOperations" contract="IEndpointOperations" bindingConfiguration="AdapterTCPBinding"/>

      <endpoint address="net.tcp://182.71.32.185:9011/GPRSAdapter/GPRSAdapterOperations.svc" binding="netTcpBinding" name="GPRSAdapterEndPointDetails" contract="IEndpointDetails" bindingConfiguration="AdapterTCPBinding"/>
   
    </client>
  </system.serviceModel>

  <log4net>
    <appender name="RollingLogFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="..\Logs\GPRSComService\GPRSScheduler.log"/>
      <appendToFile value="true"/>
      <rollingStyle value="Composite"/>
      <datePattern value="yyyyMMdd"/>
      <maxSizeRollBackups value="10"/>
      <maximumFileSize value="50MB"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline"/>
      </layout>
    </appender>
    <root>
      <level value="DEBUG"/>
      <appender-ref ref="RollingLogFileAppender"/>
    </root>
  </log4net>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6"/></startup></configuration>
