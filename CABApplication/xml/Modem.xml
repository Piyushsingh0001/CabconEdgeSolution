<?xml version="1.0" encoding="UTF-8"?>
<ModemConfig>  
  <ModemName Name="PSTNDLMS">
    <Portsettings>
      <BitsPerSecond>9600</BitsPerSecond>
      <Databits>8</Databits>
      <Parity>None</Parity>
      <Stopbits>1</Stopbits>
    </Portsettings>
    <Commandsettings>
      <Dial>ATDT</Dial>
      <Initialize>+++|ATE0|ATH|ATI0|AT+ICF=3,4|ATS0=100|AT+IPR=9600|AT&amp;W</Initialize>
      <ReConnect>+++|ATH|AT+IPR=9600|AT&amp;W</ReConnect>
       <IsReConnect>false</IsReConnect>
      <Reset>+++|ATH|AT+IPR=9600|AT&amp;W</Reset>
      <InitializeBaudRate>12</InitializeBaudRate>
      <InitializeSettings>23</InitializeSettings>
      <ResetBaudRate>34</ResetBaudRate>
      <ResetSettings>45</ResetSettings>
      <DLMSRetries>1</DLMSRetries>
      <CommandTimeout>8000</CommandTimeout>
		<InterCharacterTimeout>7000</InterCharacterTimeout>
    </Commandsettings>
    <Typeofconnection>PSTN</Typeofconnection>
  </ModemName>
