<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://iec.ch/TC57/2011/GetEndDeviceSecurityConfig#" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://iec.ch/TC57/2011/GetEndDeviceSecurityConfig#" xmlns:xs="http://www.w3.org/2001/XMLSchema">
